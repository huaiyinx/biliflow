# BiliFlow 配置

# === B站 Cookie ===
# 访问 /login 页面扫码登录即可，无需手动填写

# === SiliconFlow (SenseVoice ASR) ===
SILICONFLOW_KEY=sk-your-key-here
SILICONFLOW_BASE=https://api.siliconflow.cn/v1

# === Gemini API ===
GEMINI_KEY=sk-your-key-here
GEMINI_BASE=https://your-api-proxy.com/v1
CHAT_MODEL=gemini-3.5-flash

# === 域名 ===
DOMAIN=your-domain.com

# === Obsidian vault ===
VAULT_ROOT=/data/obsidian-vault
VAULT_BIKI_DIR=10-B站笔记

# === 自动检查间隔 (小时) ===
CHECK_INTERVAL_HOURS=6
